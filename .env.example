# Copy this to a local file (e.g. run-local.sh, see run-local.sh.example)
# and fill in real values. NEVER commit real secrets.

# --- Database (Supabase direct connection, port 5432) -----------------------
# Find these in Supabase dashboard -> Project Settings -> Database
# -> Connection string -> "URI" (direct connection, not pooler)
DATABASE_URL=jdbc:postgresql://db.<project-ref>.supabase.co:5432/postgres?sslmode=require
DB_USERNAME=postgres
DB_PASSWORD=

# --- JWT ----------------------------------------------------------------
# Reuse the value already set in your Railway project env vars so local
# and prod tokens stay compatible, or generate a new one (invalidates
# existing sessions, harmless for a personal project):
#   openssl rand -base64 64
JWT_SECRET=

# --- Teller (sandbox) -----------------------------------------------------
# From Teller dashboard after regenerating your sandbox application
TELLER_APPLICATION_ID=
TELLER_KEYSTORE_PATH=/absolute/path/to/certificate.pem
TELLER_KEYSTORE_PASSWORD=
TELLER_CONNECT_ENV=sandbox

# --- Anthropic (optional locally) ------------------------------------------
# Leave blank to disable AI categorization while testing locally
ANTHROPIC_API_KEY=

# --- CORS -------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Misc -------------------------------------------------------------
SPRING_PROFILES_ACTIVE=local
SCHEDULING_ENABLED=false
